PORT=4173

# Tuya Cloud Project > Authorization Key
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=

# Tuya data center endpoint. Korea/Singapore accounts often use Singapore, but match your project data center.
# China: https://openapi.tuyacn.com
# Western America: https://openapi.tuyaus.com
# Eastern America: https://openapi-ueaz.tuyaus.com
# Central Europe: https://openapi.tuyaeu.com
# Western Europe: https://openapi-weaz.tuyaeu.com
# India: https://openapi.tuyain.com
# Singapore: https://openapi-sg.iotbing.com
TUYA_ENDPOINT=https://openapi-sg.iotbing.com
TUYA_TIME_ZONE=Asia/Seoul

# If each room has a different H5000, map them here.
TUYA_DEVICE_ID=
TUYA_ROOM_1201_DEVICE_ID=
TUYA_ROOM_803_DEVICE_ID=
TUYA_ROOM_502_DEVICE_ID=

# Tuya projects differ in how the ticket AES key is represented.
# This H5000 project worked with full32. If ticket decrypt fails, try first16, last16, or sha256.
TUYA_AES_SECRET_MODE=full32

# Payment system
# mock: local approval for preview
# toss: Toss Payments payment window. The values below are public Toss docs test keys.
# Replace these with your own Toss Payments keys before production.
PAYMENT_PROVIDER=toss
TOSS_CLIENT_KEY=test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq
TOSS_SECRET_KEY=test_sk_zXLkKEypNArWmo50nX3lmeaxYG5R

# Kakao AlimTalk
# mock: creates and records the KakaoTalk message without sending.
# webhook: posts the AlimTalk payload to your BizMessage provider webhook.
KAKAO_ALIMTALK_PROVIDER=mock
KAKAO_ALIMTALK_WEBHOOK_URL=
KAKAO_ALIMTALK_WEBHOOK_TOKEN=
KAKAO_ALIMTALK_SENDER_KEY=
KAKAO_ALIMTALK_TEMPLATE_CODE=staypass_room_key
